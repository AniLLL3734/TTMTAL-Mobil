<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".TTMTALApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ttmtal_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ttmtal_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.TTMTALMobil"
        tools:targetApi="31">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TTMTALMobil">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".MainActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".AboutActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".ContactActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".GalleryActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".LoginActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".RegisterActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".PhotoViewerActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />
        <activity android:name=".CommonDetailActivity" android:exported="false" android:theme="@style/Theme.TTMTALMobil" />

        <service
            android:name=".services.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>